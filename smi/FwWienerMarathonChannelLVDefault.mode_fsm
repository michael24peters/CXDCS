class: $FWPART_FwWienerMarathonChannelLVDefault_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_FWWIENERMARATHONCHANNELLVDEFAULT_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_FWWIENERMARATHONCHANNELLVDEFAULT_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_FWWIENERMARATHONCHANNELLVDEFAULT_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_FWWIENERMARATHONCHANNELLVDEFAULT_FWSETACTIONS
            move_to READY

object: $FWPART_FwWienerMarathonChannelLVDefault_FWDM is_of_class $FWPART_FwWienerMarathonChannelLVDefault_FwDevMode_CLASS

