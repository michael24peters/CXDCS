class: $FWPART_FwCaenChannelLVDefault_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_FWCAENCHANNELLVDEFAULT_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_FWCAENCHANNELLVDEFAULT_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_FWCAENCHANNELLVDEFAULT_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_FWCAENCHANNELLVDEFAULT_FWSETACTIONS
            move_to READY

object: $FWPART_FwCaenChannelLVDefault_FWDM is_of_class $FWPART_FwCaenChannelLVDefault_FwDevMode_CLASS

