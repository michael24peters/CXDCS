"#uses \"fwFSM/fwFsm.ctl\"
/* **************************************************************************************

Author: Bruno Belbute
Date:   12.05.2006
NOTE:   Create the CONFIGURATORS

*************************************************************************************** */

int level = 0; // indicate at which level the creation of configurators stopped
int error = 0; // indicate if an error occured

const string lb_csConfiguratorDUTypeH = \"FwFSMConfDBDUT\";  //FSM-ConfDB configurator DU type
const string lb_csConfiguratorDUTypeL = \"FwFSMConfDBDUL\";  //FSM-ConfDB configurator DU type
const string lb_csConfiguratorDUType_DCS = \"FwFSMConfDB_DCS\";  //FSM-ConfDB configurator DU type

/* ************************************************************************************ */

main()
{
	string node;
	getValue (\"CUNAME\", \"text\", node);
	error = 0;
	level = 0;
	CREATER (node);
	if (error) return;
	if (level > 0)
	{
//		fwFsmTree_generateFsmTypes();
		fwFsmTree_generateTreeNode(node, 1);
		fwFsmTree_refreshTree();
	}
	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 1 -> END\");
}

/* ************************************************************************************ */

void CREATER (string node)
{
	dyn_string allChildren, exInfo;
	dyn_int allChildrenTypes; //1 = CU, 2 = DU, 0 = Obj or LU
	string configurator;
	int CU, LU;

	allChildren      = makeDynString ();
	allChildrenTypes = makeDynInt    ();

	allChildren = fwCU_getChildren (allChildrenTypes, node);

	if (dynlen(allChildren) == 0) {
		DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 1 -> No CONFIGURATORS to be created!!\");
		return;
	}

	//Set depth level
	level++;

	//Remove old Configurator if it exists
	if (dpExists(node + \"_ConfDB\"))
	{
		if (fwFSMConfDB_removeConfigurator(node, node + \"_ConfDB\") == -1)
		{
			error = 1;
			//DebugTN (\"ERROR : LVChannelConfDBInitializer -> Step 1 -> Error wile adding the configurator to domain \" + node + \"!!\");
			return;
		}
	}

	//Create Configurator for current node
//	if (lbFSMConfDB_addConfigurator(node) == -1)
	if (fwFSMConfDB_addConfigurator(node, \"FwFSMConfDB_DCS\") == -1)
	{
		error = 1;
		//DebugTN (\"ERROR : LVChannelConfDBInitializer -> Step 1 -> Error while adding the configurator to domain \" + node + \"!!\");
		return;
	}

	//DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 1 -> Configurator successfully added to node \" + node + \"!!\");

	//For the CU
	while ( (CU = dynContains (allChildrenTypes, 1)) > 0 )
	{
		allChildrenTypes[CU] = -1;
		CREATER (allChildren[CU]);
	}

	//For the LU
//	while ( (LU = dynContains (allChildrenTypes, 0)) > 0 )
//	{
//		allChildrenTypes[LU] = -1;
//		CREATER (allChildren[LU]);
//	}
}

/* ************************************************************************************ */

/** This function is a replica for the one on the FSMConfDB library.
		It was added to allow the configurators FwFSMConfDBUL to be automatically
		added to the tree and should be erased as soon as it is not needed

int lbFSMConfDB_addConfigurator(string sDomain)
{
  string dpName;
  string du;
  string lb_csConfiguratorDUType;
  dyn_string exceptionInfo;

	//check hierarchy

	if (RadioButton1.number == \"0\")
	{
		fwFSMConfDB_setFwHierarchy(sDomain, fwDevice_HARDWARE);
	}
	else
	if (RadioButton1.number == \"1\")
	{
		fwFSMConfDB_setFwHierarchy(sDomain, fwDevice_LOGICAL);
	}

	lb_csConfiguratorDUType = lb_csConfiguratorDUType_DCS;


  //check that we got a CU:
  if(fwFsm_isCU(sDomain,sDomain)!= 1){
    DebugN(\"ERROR: lbFSMConfDB_addConfigurator() -> The node: \" + sDomain + \" is not a control unit. Aborted.\");
	return fwFSMConfDB_ERROR;
  }

  //1.-Create associated dp:
  dpName = fwFSMConfDB_getConfiguratorName(sDomain);


  if(fwTree_isNode(dpName, exceptionInfo)){
    DebugN(\"ERROR: Configurator \" + dpName + \" already exists.\");
    return fwFSMConfDB_ERROR;
    }

   dpCreate(dpName, g_csFSMConfDBDPT);

  //2.-Create an alias for the configurator, used when working with logical hierarchy

   dpSetAlias(dpName+\".\",dpName);

  //3.-Add Du to the SMI++ domain

   du = fwFsmTree_addNode(sDomain, dpName, lb_csConfiguratorDUType, 0);

  DebugN(\"DU added: \" + dpName + \" ->>>> to domain: \" + sDomain);

  return fwFSMConfDB_OK;
} */" 0
