#uses "FwDevMode.ctl"
CODEXB_VSENSE_CODEXB_VSENSE_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VSENSE_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_VSENSE", devdp);
   fwDU_setDefaultParameters("CODEXB_VSENSE", devdp);
   if(dpConnect("cbCODEXB_VSENSE_CODEXB_VSENSE_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_VSENSE_CODEXB_VSENSE_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_VSENSE CODEXB_VSENSE_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_VSENSE_FWDM");
   if(dpDisconnect("cbCODEXB_VSENSE_CODEXB_VSENSE_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_VSENSE_CODEXB_VSENSE_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VSENSE_FWDM");
   fwDU_convertValue("CODEXB_VSENSE","CODEXB_VSENSE_FWDM");
   FwDevMode_valueChanged("CODEXB_VSENSE", devdp,
      x1, state );
   fwDU_setState("CODEXB_VSENSE", devdp, state);
}

