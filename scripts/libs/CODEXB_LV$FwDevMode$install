#uses "FwDevMode.ctl"
CODEXB_LV_CODEXB_LV_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_LV_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_LV", devdp);
   fwDU_setDefaultParameters("CODEXB_LV", devdp);
   if(dpConnect("cbCODEXB_LV_CODEXB_LV_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_LV_CODEXB_LV_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_LV CODEXB_LV_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_LV_FWDM");
   if(dpDisconnect("cbCODEXB_LV_CODEXB_LV_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_LV_CODEXB_LV_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_LV_FWDM");
   fwDU_convertValue("CODEXB_LV","CODEXB_LV_FWDM");
   FwDevMode_valueChanged("CODEXB_LV", devdp,
      x1, state );
   fwDU_setState("CODEXB_LV", devdp, state);
}

