#uses "FwDevMode.ctl"
CODEXB_VTHPHI_CODEXB_VTHPHI_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VTHPHI_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_VTHPHI", devdp);
   fwDU_setDefaultParameters("CODEXB_VTHPHI", devdp);
   if(dpConnect("cbCODEXB_VTHPHI_CODEXB_VTHPHI_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_VTHPHI_CODEXB_VTHPHI_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_VTHPHI CODEXB_VTHPHI_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_VTHPHI_FWDM");
   if(dpDisconnect("cbCODEXB_VTHPHI_CODEXB_VTHPHI_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_VTHPHI_CODEXB_VTHPHI_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VTHPHI_FWDM");
   fwDU_convertValue("CODEXB_VTHPHI","CODEXB_VTHPHI_FWDM");
   FwDevMode_valueChanged("CODEXB_VTHPHI", devdp,
      x1, state );
   fwDU_setState("CODEXB_VTHPHI", devdp, state);
}

