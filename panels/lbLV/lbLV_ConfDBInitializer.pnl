"
/* **************************************************************************************

Author: Bruno Belbute
Date:   12.05.2006
NOTE:   Create standard RECIPES
*************************************************************************************** */

// Global variables definition
string node, mode;
string hierarchyType;

dyn_string SavePopertiesNamesC;
dyn_string SavePopertiesValuesC;
dyn_int    SavePopertiesTypesC;

dyn_string SavePopertiesNamesM;
dyn_string SavePopertiesValuesM;
dyn_int    SavePopertiesTypesM;

dyn_string DataPointsDPNames;
dyn_string DataPointsDPTypes;
dyn_bool   hasCurrentAlert;

dyn_string SavePopertiesValues;

/* ************************************************************************************ */

main()
{
        dynClear(DataPointsDPNames);
        dynClear(DataPointsDPTypes);
        dynClear(SavePopertiesValues);
        dynClear(hasCurrentAlert);

	getValue (\"CUNAME\", \"text\", node);
	getValue (\"MODE\"  , \"text\", mode);


	GETSAVEPROPERTIES ();

	GETDPS (node);

	GETDPES ();

	CREATERECIPECACHES ();

	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 2 -> END\");
}

/* **************************************************************************************
Function: GETSAVEPROPERTIES ()
Author: Bruno Belbute
Date:   12.05.2006
NOTE:

*************************************************************************************** */
void GETSAVEPROPERTIES ()
{
	//CAEN
	string i0value, rDvalue, rUvalue, tTvalue, v0value, vMvalue;

	getValue (\"i0\", \"text\", i0value);
	getValue (\"v0\", \"text\", v0value);
	getValue (\"rD\", \"text\", rDvalue);
	getValue (\"rU\", \"text\", rUvalue);
	getValue (\"tT\", \"text\", tTvalue);
	getValue (\"vM\", \"text\", vMvalue);


	SavePopertiesNamesC = makeDynString (
		\".settings.i0\"       ,
// 		\".settings.i1\"       ,
		\".settings.onOff\"    ,
		\".settings.rDwn\"     ,
		\".settings.rUp\"      ,
		\".settings.tripTime\" ,
		\".settings.v0\"       //,
// 		\".settings.v1\"       ,
// 		\".settings.vMaxSoftValue\"
    );

	SavePopertiesValuesC = makeDynString (
		i0value    ,
// 		\"0\"        ,
		\"TRUE\"     ,
		rDvalue    ,
		rUvalue    ,
		tTvalue    ,
		v0value    //,
// 		\"0\"        ,
// 		vMvalue
    );

	SavePopertiesTypesC = makeDynInt (
		22 ,
// 		22 ,
		23 ,
		22 ,
		22 ,
		22 ,
		22 //,
// 		22 ,
// 		22
    );


	//MARATHON
	string mCvalue, mSVvalue;

	getValue (\"maxC\", \"text\", mCvalue);
	getValue (\"maxSV\", \"text\", mSVvalue);

	SavePopertiesNamesM = makeDynString (
		\".Settings.OnOffChannel\" ,
		\".Settings.SueprvisionMaxCurrent\" ,
                \".settings.SueprvisionMaxSenseVoltage\" );

	SavePopertiesValuesM = makeDynString (
		\"TRUE\" ,
		mCvalue ,
                mSVvalue );

	SavePopertiesTypesM = makeDynInt (
		23 ,
		22 ,
                22 );

	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 2 -> Save Properties created!!\");
}

/* **************************************************************************************
Function: GETDPS (string node)
Author: Bruno Belbute
Date:   12.05.2006
NOTE:

*************************************************************************************** */
void GETDPS (string node)
{
	dyn_string allChildren;
	dyn_int allChildrenTypes; //1 = CU, 2 = DU, 0 = Obj or LU
	string DUName;
	string type, typeLVMarathon;
	int CU, LU;
	int position;
	dyn_string typeDeviceAll = makeDynString (\"FwCaenChannelA2551\", typeFSMCaen, typeFSMMarathon);

	typeLVMarathon = typeFSMMarathon;
	strreplace(typeLVMarathon,\"Default\", \"\");

	allChildren = fwCU_getChildren (allChildrenTypes, node);
	if (dynlen(allChildren) == 0)
	{
		DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 2 -> No DU to include on the RecipeCache for node \" + node + \"!!\");
		return;
	}

	//Add the current node children's
	for (int i = 1; i <= dynlen(allChildren); i++)
	{
		fwCU_getType (allChildren[i], type);
		position = dynContains (typeDeviceAll, type);
		if ((position > 0) || (strpos(type,typeLVMarathon) == 0))
		{
                  string DPName;
                        if(fwFsm_isLogicalDeviceName(allChildren[i]))
                        {
				DUName = allChildren[i];
                                DPName = dpAliasToName( DUName );
                        }
                        else
                        {
				DUName = getSystemName() + allChildren[i];
                                DPName = DUName;
                        }

			dynAppend (DataPointsDPNames, DUName);
			dynAppend (DataPointsDPTypes, type);

                        //DebugN(DPName, position);
                        string currentDPEName;
                        if ( position == 1 )       //CAEN
                          currentDPEName = \".actual.iMon\";
                        else
                          currentDPEName = \".MeasurementCurrent\";

                        int alertConfType;
                        dpGet(DPName+currentDPEName+\":_alert_hdl.._type\", alertConfType);
                        if ( alertConfType == DPCONFIG_ALERT_NONBINARYSIGNAL )
                        {
                          dynAppend(hasCurrentAlert, true);
                          DebugN(\"INFO: Adding alerts for dpe:\"+DPName+currentDPEName);
                        }
                        else
                          dynAppend(hasCurrentAlert, false);

		}
	}
	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 2 -> All DU's for node \" + node + \" included!!\");

	//For the CU
	while ( (CU = dynContains (allChildrenTypes, 1)) > 0 )
	{
		allChildrenTypes[CU] = -1;
		GETDPS (allChildren[CU]);
	}

	//For the LU
	while ( (LU = dynContains (allChildrenTypes, 0)) > 0 )
	{
		allChildrenTypes[LU] = -1;
		GETDPS (allChildren[LU]);
	}
}

/* ************************************************************************************ */

void GETDPES ()
{
	for (int i=1; i<=dynlen(DataPointsDPNames); i++)
	{
		if (DataPointsDPTypes[i] == typeFSMCaen ||
        DataPointsDPTypes[i] == \"FwCaenChannelA2551\" )
		{ //CAEN
			for (int j=1; j<=dynlen(SavePopertiesNamesC); j++)
			{
				dynAppend (SavePopertiesValues, SavePopertiesValuesC[j]);
			}
                        if ( hasCurrentAlert[i] ) dynAppend( SavePopertiesValues, \"\" );
		}
		else
		{
			string type = typeFSMMarathon;
			strreplace(type,\"Default\", \"\");
			if(strpos(DataPointsDPTypes[i],type) == 0)
//		if (DataPointsDPTypes[i] == typeFSMMarathon)
			{ //MARATHON LV
				for (int j=1; j<=dynlen(SavePopertiesNamesM); j++)
				{
					dynAppend (SavePopertiesValues, SavePopertiesValuesM[j]);
				}
                                if ( hasCurrentAlert[i] ) dynAppend( SavePopertiesValues, \"\" );
			}
		}
	}

	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 2 -> All DU DPE's for node \" + node + \" included!!\");
}

/* **************************************************************************************
Function: void CREATERECIPECACHES ()
Author: Bruno Belbute
Date:   12.05.2006
NOTE:

*************************************************************************************** */
void CREATERECIPECACHES ()
{
	dyn_dyn_mixed recipeObject;
	dyn_dyn_mixed oldObject;
	dyn_dyn_mixed finalObject;
	dyn_string deviceList;
	dyn_string exInfo;

	//Initialization
	fwConfigurationDB_initialize (\"\", exInfo);

	//Create Hierarchy
	deviceList = DataPointsDPNames;

	//Set the recipe type
	fwConfigurationDB_setRecipeType (\"LVChannelRecipeType\", exInfo);

	//Get the recipe data
	fwConfigurationDB_extractRecipe (deviceList, hierarchyType, recipeObject, exInfo);

// DebugTN(\"****\", SavePopertiesValues);
	//COMMAND Switch_ON
	recipeObject[fwConfigurationDB_RO_VALUE] = SavePopertiesValues;

	fwConfigurationDB_loadRecipeFromCache(mode + \"/Switch_ON\", makeDynString(), hierarchyType, oldObject, exInfo);
        dynClear(exInfo);

        //DebugN(recipeObject);
        if(dynlen(oldObject[fwConfigurationDB_RO_VALUE]))
        {
	    fwConfigurationDB_combineRecipes(finalObject, oldObject, recipeObject, exInfo);
            fwConfigurationDB_saveRecipeToCache(finalObject, hierarchyType, mode + \"/Switch_ON\", exInfo);
        }
        else {
// DebugTN(\"+++++\", recipeObject);
    	    fwConfigurationDB_saveRecipeToCache(recipeObject, hierarchyType, mode + \"/Switch_ON\", exInfo);
        }

	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 2 -> Standard Recipes created!!\");
}


