#uses "FwDevMode.ctl"
CODEXB_VDIGITAL_CODEXB_VDIGITAL_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VDIGITAL_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_VDIGITAL", devdp);
   fwDU_setDefaultParameters("CODEXB_VDIGITAL", devdp);
   if(dpConnect("cbCODEXB_VDIGITAL_CODEXB_VDIGITAL_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_VDIGITAL_CODEXB_VDIGITAL_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_VDIGITAL CODEXB_VDIGITAL_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_VDIGITAL_FWDM");
   if(dpDisconnect("cbCODEXB_VDIGITAL_CODEXB_VDIGITAL_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_VDIGITAL_CODEXB_VDIGITAL_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VDIGITAL_FWDM");
   fwDU_convertValue("CODEXB_VDIGITAL","CODEXB_VDIGITAL_FWDM");
   FwDevMode_valueChanged("CODEXB_VDIGITAL", devdp,
      x1, state );
   fwDU_setState("CODEXB_VDIGITAL", devdp, state);
}

