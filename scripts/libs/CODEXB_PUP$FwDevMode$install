#uses "FwDevMode.ctl"
CODEXB_PUP_CODEXB_PUP_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_PUP_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_PUP", devdp);
   fwDU_setDefaultParameters("CODEXB_PUP", devdp);
   if(dpConnect("cbCODEXB_PUP_CODEXB_PUP_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_PUP_CODEXB_PUP_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_PUP CODEXB_PUP_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_PUP_FWDM");
   if(dpDisconnect("cbCODEXB_PUP_CODEXB_PUP_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_PUP_CODEXB_PUP_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_PUP_FWDM");
   fwDU_convertValue("CODEXB_PUP","CODEXB_PUP_FWDM");
   FwDevMode_valueChanged("CODEXB_PUP", devdp,
      x1, state );
   fwDU_setState("CODEXB_PUP", devdp, state);
}

