class: $FWPART_FwCaenChannelA2551_FwDevMode_CLASS
    state: READY
        action: Disable(Device)
            remove &VAL_OF_Device from $FWPART_FWCAENCHANNELA2551_FWSETSTATES
            remove &VAL_OF_Device from $FWPART_FWCAENCHANNELA2551_FWSETACTIONS
            move_to READY
        action: Enable(Device)
            insert &VAL_OF_Device in $FWPART_FWCAENCHANNELA2551_FWSETSTATES
            insert &VAL_OF_Device in $FWPART_FWCAENCHANNELA2551_FWSETACTIONS
            move_to READY

object: $FWPART_FwCaenChannelA2551_FWDM is_of_class $FWPART_FwCaenChannelA2551_FwDevMode_CLASS

