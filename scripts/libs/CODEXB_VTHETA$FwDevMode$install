#uses "FwDevMode.ctl"
CODEXB_VTHETA_CODEXB_VTHETA_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VTHETA_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_VTHETA", devdp);
   fwDU_setDefaultParameters("CODEXB_VTHETA", devdp);
   if(dpConnect("cbCODEXB_VTHETA_CODEXB_VTHETA_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_VTHETA_CODEXB_VTHETA_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_VTHETA CODEXB_VTHETA_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_VTHETA_FWDM");
   if(dpDisconnect("cbCODEXB_VTHETA_CODEXB_VTHETA_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_VTHETA_CODEXB_VTHETA_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VTHETA_FWDM");
   fwDU_convertValue("CODEXB_VTHETA","CODEXB_VTHETA_FWDM");
   FwDevMode_valueChanged("CODEXB_VTHETA", devdp,
      x1, state );
   fwDU_setState("CODEXB_VTHETA", devdp, state);
}

