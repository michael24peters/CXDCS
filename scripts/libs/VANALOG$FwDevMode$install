#uses "FwDevMode.ctl"
VANALOG_VANALOG_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("VANALOG_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("VANALOG", devdp);
   fwDU_setDefaultParameters("VANALOG", devdp);
   if(dpConnect("cbVANALOG_VANALOG_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

VANALOG_VANALOG_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling VANALOG VANALOG_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("VANALOG_FWDM");
   if(dpDisconnect("cbVANALOG_VANALOG_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbVANALOG_VANALOG_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("VANALOG_FWDM");
   fwDU_convertValue("VANALOG","VANALOG_FWDM");
   FwDevMode_valueChanged("VANALOG", devdp,
      x1, state );
   fwDU_setState("VANALOG", devdp, state);
}

