/* ************************************************************************************** 

Author: Bruno Belbute
Date:   12.05.2006  
NOTE:   Set the DU's INVISIBLE

*************************************************************************************** */

main()
{
	string node;
	getValue (\"CUNAME\", \"text\", node);
	VISIBILITY (node);
	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 3 -> END\");
}


void VISIBILITY (string cu, string lu = \"\")
{
	dyn_string allFSMDevices;
	dyn_string allChildren;
	dyn_int allChildrenTypes; //1 = CU, 2 = DU, 0 = Obj or LU
	int i, CU, LU, found = 0;
	string type, node;

	allFSMDevices    = makeDynString ();
	allChildren      = makeDynString ();
	allChildrenTypes = makeDynInt    ();

	node = cu;
	if(lu != \"\")
		node = lu;

	allChildren = fwCU_getChildren (allChildrenTypes, node);

	for(i = 1; i <= dynlen(allChildren); i++)
	{
		if(allChildrenTypes[i] == 2)
		{
			fwCU_getType(node+\"::\"+allChildren[i], type);
			if((type == typeFSMCaen) || (type == typeFSMMarathon))
			{
				found = 1;
				fwFsm_setObjectLabelPanel(cu, allChildren[i],\"\",\"\",0, -1);
			}
		}
	}
	DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 3 -> All DU's of type \"+typeFSMCaen+\" for node \" + node + \" set to INVISIBLE!!\");

	if(found)
	{
		if(lu == \"\")
			lu = cu;
		fwFsm_setObjectLabelPanel(cu, lu,\"\",\"lbLV/lbLV.pnl\", -1, -1);
		DebugTN (\"INFO : CAENHVChannelConfDBInitializer -> Step 3 -> Panel for node \" + lu + \" set to lbLV.pnl\");
	}
/*
	if (dynlen(allChildren) == 0)
	{
		DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 3 -> No DU to set INVISIBLE!!\");
		return;
	}

	//Set the current CU children's INVISIBLE
	allFSMDevices = dpNames (node + \"|*\",\"_FwFsmDevice\");
	
	for (int i=1; i<=dynlen(allFSMDevices); i++)
	{
		if (dpSubStr(allFSMDevices[i], DPSUB_DP_EL) != (node + \"|\" + node + \"_FWDM\"))
			dpSet (allFSMDevices[i] + \".ui.visible\", FALSE);
	}

	DebugTN (\"INFO : LVChannelConfDBInitializer -> Step 3 -> All DU's for node \" + node + \" set to INVISIBLE!!\");
*/

	//For the CU
	while ( (CU = dynContains (allChildrenTypes, 1)) > 0 )
	{
		allChildrenTypes[CU] = -1;	
		VISIBILITY (allChildren[CU]);	
	}

	//For the LU
	while ( (LU = dynContains (allChildrenTypes, 0)) > 0 )
	{
		allChildrenTypes[LU] = -1;	
		VISIBILITY (node, allChildren[LU]);	
	}

