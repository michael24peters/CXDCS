#uses "FwDevMode.ctl"
VSENSE_VSENSE_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("VSENSE_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("VSENSE", devdp);
   fwDU_setDefaultParameters("VSENSE", devdp);
   if(dpConnect("cbVSENSE_VSENSE_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

VSENSE_VSENSE_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling VSENSE VSENSE_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("VSENSE_FWDM");
   if(dpDisconnect("cbVSENSE_VSENSE_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbVSENSE_VSENSE_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("VSENSE_FWDM");
   fwDU_convertValue("VSENSE","VSENSE_FWDM");
   FwDevMode_valueChanged("VSENSE", devdp,
      x1, state );
   fwDU_setState("VSENSE", devdp, state);
}

