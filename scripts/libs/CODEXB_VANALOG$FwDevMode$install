#uses "FwDevMode.ctl"
CODEXB_VANALOG_CODEXB_VANALOG_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VANALOG_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("CODEXB_VANALOG", devdp);
   fwDU_setDefaultParameters("CODEXB_VANALOG", devdp);
   if(dpConnect("cbCODEXB_VANALOG_CODEXB_VANALOG_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

CODEXB_VANALOG_CODEXB_VANALOG_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling CODEXB_VANALOG CODEXB_VANALOG_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("CODEXB_VANALOG_FWDM");
   if(dpDisconnect("cbCODEXB_VANALOG_CODEXB_VANALOG_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbCODEXB_VANALOG_CODEXB_VANALOG_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CODEXB_VANALOG_FWDM");
   fwDU_convertValue("CODEXB_VANALOG","CODEXB_VANALOG_FWDM");
   FwDevMode_valueChanged("CODEXB_VANALOG", devdp,
      x1, state );
   fwDU_setState("CODEXB_VANALOG", devdp, state);
}

