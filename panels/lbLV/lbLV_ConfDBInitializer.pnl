"main()
{
	//CAEN
	setValue (\"i0\", \"text\", \"10\" );
	setValue (\"v0\", \"text\", \"5\");
	setValue (\"rD\", \"text\", \"10\" );
	setValue (\"rU\", \"text\", \"10\" );
	setValue (\"tT\", \"text\", \"3\"  );
	setValue (\"vM\", \"text\", \"20\");
	
	setValue (\"Texti0\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.i0\"));
	setValue (\"Textv0\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\"));
	setValue (\"TextrD\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rDwn\"));
	setValue (\"TextrU\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rUp\"));
	setValue (\"TexttT\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.tripTime\"));
	setValue (\"TextvM\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.vMaxSoftValue\"));
	
	setValue (\"i0\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.i0\"));
	setValue (\"v0\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.v0\"));
	setValue (\"rD\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rDwn\"));
	setValue (\"rU\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.rUp\"));
	setValue (\"tT\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.tripTime\"));
	setValue (\"vM\", \"toolTipText\", getDpeName(typeDPCaen, \".settings.vMaxSoftValue\"));


	//MARATHON
	setValue (\"maxC\", \"text\", \"10\" );
	setValue (\"maxSV\", \"text\", \"5\" );

	setValue (\"maxCText\", \"toolTipText\", getDpeName(typeDPMarathon, \".Settings.SupervisionMaxCurrent\"));
        setValue (\"maxSVText\", \"toolTipText\", getDpeName(typeDPMarathon, \".Settings.SupervisionMaxSenseVoltage\"));

	setValue (\"maxC\", \"toolTipText\", getDpeName(typeDPMarathon, \".Settings.SupervisionMaxCurrent\"));
	setValue (\"maxSV\", \"toolTipText\", getDpeName(typeDPMarathon, \".Settings.SupervisionMaxSenseVoltage\"));        
}" 0
