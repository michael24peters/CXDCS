#uses "FwDevMode.ctl"
ETA_THRESHOLD_ETA_THRESHOLD_FWDM_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("ETA_THRESHOLD_FWDM");
   if(!globalExists("FwDevMode_CurrDUActions"))
   {
      addGlobal("FwDevMode_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwDevMode",FwDevMode_CurrDUActions);
   }
   FwDevMode_initialize("ETA_THRESHOLD", devdp);
   fwDU_setDefaultParameters("ETA_THRESHOLD", devdp);
   if(dpConnect("cbETA_THRESHOLD_ETA_THRESHOLD_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
}

ETA_THRESHOLD_ETA_THRESHOLD_FWDM_uninstall(string dp, int running)
{
   string devdp;

DebugTN("uninstalling ETA_THRESHOLD ETA_THRESHOLD_FWDM");
   if(running) return;
   devdp = ""+fwDU_getPhysicalName("ETA_THRESHOLD_FWDM");
   if(dpDisconnect("cbETA_THRESHOLD_ETA_THRESHOLD_FWDM_valueChanged",
      devdp+".disabled:_online.._value"
     ) == -1 )
      DebugTN("Bad dpDisconnect state");
}

cbETA_THRESHOLD_ETA_THRESHOLD_FWDM_valueChanged(
      string dp1, dyn_string x1   )
{
   string state;
   string devdp;

   devdp = ""+fwDU_getPhysicalName("ETA_THRESHOLD_FWDM");
   fwDU_convertValue("ETA_THRESHOLD","ETA_THRESHOLD_FWDM");
   FwDevMode_valueChanged("ETA_THRESHOLD", devdp,
      x1, state );
   fwDU_setState("ETA_THRESHOLD", devdp, state);
}

