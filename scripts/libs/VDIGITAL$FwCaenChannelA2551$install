VDIGITAL_CAEN_cxcaen01_board10_channel003_install()
{
   string devdp;

   devdp = ""+fwDU_getPhysicalName("CAEN/cxcaen01/board10/channel003");
   if(!globalExists("FwCaenChannelA2551_CurrDUActions"))
   {
      addGlobal("FwCaenChannelA2551_CurrDUActions",DYN_STRING_VAR);
      fwDU_getAllActions("FwCaenChannelA2551",FwCaenChannelA2551_CurrDUActions);
   }
   FwCaenChannelA2551_initialize("VDIGITAL", devdp);
   fwDU_setDefaultParameters("VDIGITAL", devdp);
   if(dpConnect("cbVDIGITAL_CAEN_cxcaen01_board10_channel003_valueChanged",
      devdp+".actual.status:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect state");
   if(dpConnect("cbVDIGITAL_CAEN_cxcaen01_board10_channel003_doCommand",false,
     "VDIGITAL|CAEN/cxcaen01/board10/channel003.fsm.sendCommand:_online.._value"
     ) == -1 )
      DebugTN("Bad dpConnect command");
}

